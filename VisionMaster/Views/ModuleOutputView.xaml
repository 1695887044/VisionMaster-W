<UserControl x:Class="VisionMaster.Views.ModuleOutputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:local="clr-namespace:VisionMaster.Views"
             xmlns:vm="clr-namespace:VisionMaster.ViewModels"
             xmlns:helpers="clr-namespace:VisionMaster.Helpers"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="10,12,10,8" Background="#F8F9FA" BorderBrush="#EBEEF5" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="添加监视:" Foreground="#909399" FontWeight="SemiBold" 
                           VerticalAlignment="Center" Margin="12,0,8,0" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="SearchTextBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" 
                             VerticalContentAlignment="Center" Height="34" Width="250"
                             Foreground="#303133" FontSize="13"
                             Tag="{Binding}"
                             ToolTip="输入算子名或变量名进行搜索，按Enter添加监视">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding AddWatchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    
                    <Popup x:Name="SuggestionPopup" Placement="Bottom" 
                           IsOpen="{Binding IsDropDownOpen}"
                           StaysOpen="False" PopupAnimation="Fade"
                           Width="{Binding ElementName=SearchTextBox, Path=ActualWidth}">
                        <Border Background="White" BorderBrush="#EBEEF5" BorderThickness="1" 
                                MaxHeight="200">
                            <ListView ItemsSource="{Binding SuggestedItems}"
                                      SelectedItem="{Binding SelectedSuggestion}"
                                      Background="Transparent" BorderThickness="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#ECF5FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" 
                                                   FontSize="13" Foreground="#606266"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Popup>
                </StackPanel>

                <Button Grid.Column="2" Content="清空全部" Width="80" Height="28" Margin="8,3,12,3"
                        Background="#F56C6C" Foreground="White" BorderThickness="0"
                        Command="{Binding ClearAllCommand}"
                        ToolTip="清空所有监视项">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E85D5D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,8">
            <Button Content="全局变量" Height="28" Padding="12,0" Margin="0,0,8,0"
                    Background="#67C23A" Foreground="White" BorderThickness="0"
                    Command="{Binding QuickAddCommand}" CommandParameter="Global.All"
                    ToolTip="快速添加所有全局变量">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#5EB83A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="全部输入" Height="28" Padding="12,0" Margin="0,0,8,0"
                    Background="#409EFF" Foreground="White" BorderThickness="0"
                    ToolTip="添加所有输入端口">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3690E6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="全部输出" Height="28" Padding="12,0"
                    Background="#E6A23C" Foreground="White" BorderThickness="0"
                    ToolTip="添加所有输出端口">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="12,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D99332"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <ListBox Grid.Row="2" ItemsSource="{Binding DisplayPorts}" Margin="10"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4"/>
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F7FA"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#409EFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="类型: " Foreground="#909399" FontSize="11"/>
                            <TextBlock Text="{Binding TypeName}" Foreground="#909399" FontSize="11"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="{Binding DisplayValue}" 
                                   Foreground="#E6A23C" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Right" Margin="0,0,8,0"/>

                        <Border Grid.Column="2" Background="#F4F4F5" CornerRadius="4" 
                                Padding="6,2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Direction}" FontSize="11" Foreground="#909399"/>
                        </Border>

                        <Button Grid.Column="3" Background="Transparent" BorderThickness="0" 
                                Width="20" Height="20" Cursor="Hand"
                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                ToolTip="移除监视">
                            <TextBlock FontFamily="{StaticResource Icon}" FontSize="12" Foreground="#F56C6C" Text="&#xf1f8;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,8,10,12">
            <TextBlock Text="监视项:" Foreground="#909399" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DisplayPorts.Count}" Foreground="#409EFF" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>