<UserControl
    x:Class="VisionMaster.Views.ToolView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:enums="clr-namespace:VisionMaster"
    
    xmlns:ui="http://schemas.UI.com/ui"
    xmlns:local="clr-namespace:VisionMaster.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="600"
    d:DesignWidth="250"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid Background="#FFFFFF">
        <Grid.Resources>
            <ui:BindingProxy x:Key="MyViewModelProxy" Data="{Binding}" />
            <Style x:Key="FunctionIconStyle" TargetType="TextBlock">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="FunctionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="9" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <DataTemplate x:Key="MyDragAdornerTemplate">
                <Border
                    Width="50"
                    Height="50"
                    Style="{StaticResource WhiteThemeToolCardStyle}"
                    ToolTip="{Binding Description}">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            FontFamily="{StaticResource  Icon}"
                            FontSize="18"
                            Foreground="#4A5568"
                            Style="{StaticResource FunctionIconStyle}"
                            Text="{Binding Icon}" />
                        <TextBlock
                            Grid.Row="1"
                            MaxWidth="32"
                            Foreground="#2D3748"
                            Style="{StaticResource FunctionTextStyle}"
                            Text="{Binding Name}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="400" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel
                Grid.Row="0"
                Background="#F3F3F3"
                Orientation="Horizontal">
                <Button
                    Margin="5,0"
                    CommandParameter="{x:Static enums:FlowAction.BrowseList}"
                    Content="&#xf013;"
                    FontFamily="{StaticResource Icon}"
                    Foreground="#005A9E"
                    Style="{StaticResource IconButon}"
                    ToolTip="程序管理" />
            </StackPanel>
            <ListBox
                Grid.Row="1"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding Workspace.CurrentSolution.Flows }"
                SelectedItem="{Binding SelectFlow}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2,0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        x:Name="ItemBorder"
                                        Padding="10,8"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F0F4F8" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#E5F1FB" />
                                            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="85" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource  Icon}"
                                FontSize="16"
                                Foreground="#007ACC"
                                Text="&#xf1c9;" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="#333333"
                                Text="{Binding FlowName}" />
                            <TextBlock
                                Grid.Column="2"
                                MaxWidth="180"
                                Margin="2,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="Green"
                                Text="{Binding Description}"
                                TextTrimming="CharacterEllipsis"
                                ToolTip="{Binding Description}" />
                            <Grid.ContextMenu>
                                <ContextMenu FontFamily="{StaticResource  Icon}">
                                    <MenuItem Header="流程" Icon="&#xf0e8;">
                                        <MenuItem
                                            Command="{Binding Data.FlowCommand, Source={StaticResource MyViewModelProxy}}"
                                            CommandParameter="{x:Static enums:FlowAction.Create}"
                                            Header="添加"
                                            Icon="&#xf56f;" />
                                        <MenuItem
                                            Command="{Binding Data.FlowCommand, Source={StaticResource MyViewModelProxy}}"
                                            CommandParameter="{x:Static enums:FlowAction.Delete}"
                                            Header="删除"
                                            Icon="&#xf2ed;" />
                                        <MenuItem
                                            Command="{Binding Data.FlowCommand, Source={StaticResource MyViewModelProxy}}"
                                            CommandParameter="{x:Static enums:FlowAction.Rename}"
                                            Header="重命名"
                                            Icon="&#xf044;" />
                                        <MenuItem
                                            Command="{Binding Data.FlowCommand, Source={StaticResource MyViewModelProxy}}"
                                            CommandParameter="{x:Static enums:FlowAction.EditComment}"
                                            Header="编辑注释"
                                            Icon="&#xf075;" />
                                    </MenuItem>
                                    <MenuItem Header="流程加密" Icon="&#xf132;">
                                        <MenuItem
                                            Command="{Binding Data.FlowCommand, Source={StaticResource MyViewModelProxy}}"
                                            CommandParameter="{x:Static enums:FlowAction.Encrypt}"
                                            Header="加密流程"
                                            Icon="&#xf023;" />
                                        <MenuItem
                                            Command="{Binding Data.FlowCommand, Source={StaticResource MyViewModelProxy}}"
                                            CommandParameter="{x:Static enums:FlowAction.Decrypt}"
                                            Header="解密流程"
                                            Icon="&#xf09c;" />
                                    </MenuItem>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <GridSplitter
            Grid.Row="1"
            Height="2"
            HorizontalAlignment="Stretch" />
        <Grid Grid.Row="2">
            <Border
                Background="#FFFFFF"
                BorderBrush="#E4E7ED"
                BorderThickness="0,0,0,1" />
            <ItemsControl Background="{StaticResource PanelBackgroundBrush}" ItemsSource="{Binding ToolBarSource}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!--  分组容器  -->
                        <Expander
                            Background="Transparent"
                            BorderBrush="{StaticResource ToolBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Header="{Binding Name}"
                            IsExpanded="True">
                            <Expander.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="5,8"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        Text="{Binding}" />
                                </DataTemplate>
                            </Expander.HeaderTemplate>

                            <!--  工具列表  -->
                            <ItemsControl
                                Margin="10,5"
                                dd:DragDrop.DragAdornerTemplate="{StaticResource MyDragAdornerTemplate}"
                                dd:DragDrop.IsDragSource="True"
                                dd:DragDrop.UseDefaultDragAdorner="True"
                                dd:DragDrop.UseDefaultEffectDataTemplate="True"
                                ItemsSource="{Binding Children}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="50"
                                            Height="50"
                                            Style="{StaticResource WhiteThemeToolCardStyle}"
                                            ToolTip="{Binding Description}">
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock
                                                    Grid.Row="0"
                                                    FontFamily="{StaticResource  Icon}"
                                                    FontSize="18"
                                                    Foreground="#4A5568"
                                                    Style="{StaticResource FunctionIconStyle}"
                                                    Text="{Binding Icon}" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    MaxWidth="32"
                                                    Foreground="#2D3748"
                                                    Style="{StaticResource FunctionTextStyle}"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
