<UserControl
    x:Class="VisionMaster.Views.VariableBindingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:VisionMaster.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:ui="http://schemas.UI.com/ui"
    Width="900"
    Height="580"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="WindowStyle" Value="None" />
            <Setter Property="ResizeMode" Value="NoResize" />
            <Setter Property="SizeToContent" Value="WidthAndHeight" />
        </Style>
    </prism:Dialog.WindowStyle>

    <UserControl.Resources>
        <Style x:Key="NoWarningItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F5F7FA" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#ECF5FF" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#409EFF" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetOptionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="MinWidth" Value="60" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#DCDFE6" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#ECF5FF" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#409EFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#409EFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#F5F7FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="SelectedPresetOptionButtonStyle"
            BasedOn="{StaticResource PresetOptionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#409EFF" />
            <Setter Property="BorderBrush" Value="#409EFF" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="InputPortItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#E4E7ED"
                            BorderThickness="0,0,0,1"
                            CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F5F7FA" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#ECF5FF" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#409EFF" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="InputPortTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Orientation="Horizontal">
                    <TextBlock
                        FontFamily="{StaticResource Icon}"
                        FontSize="14"
                        Foreground="#E6A23C"
                        Text="&#xf090;" />
                    <TextBlock
                        Margin="4,0,0,0"
                        FontWeight="SemiBold"
                        Foreground="#303133"
                        Text="{Binding Definition.Name}" />
                </StackPanel>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontSize="11"
                    Foreground="#909399"
                    Text="{Binding Definition.DataTypeName, Converter={ui:TypeNameToFriendlyNameConverter}}" />

                <Border
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="4,2"
                    Background="#FFFBE6"
                    BorderBrush="#E6A23C"
                    BorderThickness="1"
                    CornerRadius="3"
                    Visibility="{Binding Definition.IsFunctionalEnum, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#E6A23C"
                        Text="枚举" />
                </Border>
                <Border
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="4,2"
                    Background="#ECF5FF"
                    BorderBrush="#B3D8FF"
                    BorderThickness="1"
                    CornerRadius="3"
                    Visibility="{Binding Definition.IsFunctionalEnum, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}">
                    <TextBlock
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#409EFF"
                        Text="变量" />
                </Border>

                <StackPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="18,2,0,0"
                    Orientation="Horizontal"
                    Visibility="{Binding IsBound, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        FontSize="10"
                        Foreground="#67C23A"
                        Text="已绑定:" />
                    <TextBlock
                        Margin="4,0,0,0"
                        FontSize="10"
                        Foreground="#67C23A"
                        Text="{Binding LinkedAddress}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="15">
        <Border Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="15"
                    Direction="270"
                    Opacity="0.15"
                    ShadowDepth="3"
                    Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="50" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    ui:WindowDragBehavior.IsWindowDraggable="True"
                    Background="#F8F9FA"
                    BorderBrush="#EBEEF5"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0">
                    <TextBlock
                        Margin="20,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="#303133"
                        Text="变量绑定" />
                </Border>

                <Grid Grid.Row="1" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Background="#FFFFFF"
                        BorderBrush="#E4E7ED"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Background="#F5F7FA"
                                BorderBrush="#E4E7ED"
                                BorderThickness="0,0,0,1"
                                CornerRadius="6,6,0,0">
                                <TextBlock
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="#606266"
                                    Text="当前算子输入" />
                            </Border>
                            <ListBox
                                Grid.Row="1"
                                Margin="2"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource InputPortItemStyle}"
                                ItemTemplate="{StaticResource InputPortTemplate}"
                                ItemsSource="{Binding DisplayDataPort}"
                                SelectedItem="{Binding SelectedInputPort}" />
                        </Grid>
                    </Border>

                    <GridSplitter
                        Grid.Column="1"
                        Width="8"
                        HorizontalAlignment="Center"
                        Background="Transparent" />

                    <Border
                        Grid.Column="2"
                        Background="#FFFFFF"
                        BorderBrush="#E4E7ED"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Background="#F5F7FA"
                                BorderBrush="#E4E7ED"
                                BorderThickness="0,0,0,1"
                                CornerRadius="6,6,0,0">
                                <TextBlock
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="#606266"
                                    Text="选择上游算子" />
                            </Border>
                            <ListBox
                                Grid.Row="1"
                                Margin="2"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource NoWarningItemStyle}"
                                ItemsSource="{Binding TreeNodes}"
                                SelectedItem="{Binding SelectedNode}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2" Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Icon}"
                                                FontSize="16"
                                                Foreground="#409EFF"
                                                Text="{Binding Icon}" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Foreground="#303133"
                                                    Text="{Binding ModuleGroup}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="10"
                                                    Foreground="#C0C4CC"
                                                    Text="{Binding Description}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <GridSplitter
                        Grid.Column="3"
                        Width="8"
                        HorizontalAlignment="Center"
                        Background="Transparent" />
                    <Border
                        Grid.Column="4"
                        Background="#FFFFFF"
                        BorderBrush="#E4E7ED"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                Background="#F0F9EB"
                                BorderBrush="#E4E7ED"
                                BorderThickness="0,0,0,1"
                                CornerRadius="6,6,0,0">
                                <TextBlock
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="#529B2E"
                                    Text="绑定选项" />
                            </Border>

                            <Grid Grid.Row="1" Visibility="{Binding HasFunctionalEnumPort, Converter={ui:BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="12,12,12,0">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#606266"
                                        Text="常量值输入" />
                                    <Border
                                        Height="32"
                                        Background="#FFFFFF"
                                        BorderBrush="#DCDFE6"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <TextBox
                                            Padding="8,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="13"
                                            Foreground="#303133"
                                            Text="{Binding ConstantValue}" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="#C0C4CC"
                                        Text="提示：输入数值、字符串或布尔值(true/false)" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    Margin="12,15,12,8"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#606266"
                                        Text="或 绑定上游输出端口" />
                                </StackPanel>



                                <Border
                                    Grid.Row="2"
                                    Margin="12,0,12,12"
                                    Background="#FAFAFA"
                                    BorderBrush="#EBEEF5"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <ListBox
                                        Margin="2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemContainerStyle="{StaticResource NoWarningItemStyle}"
                                        ItemsSource="{Binding DisplayPorts}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Background="Transparent">
                                                    <Grid.InputBindings>
                                                        <MouseBinding
                                                            Command="{Binding DataContext.DoublockClickBindCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding}"
                                                            MouseAction="LeftDoubleClick" />
                                                    </Grid.InputBindings>
                                                    <StackPanel Margin="4,5" Orientation="Horizontal">
                                                        <TextBlock
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Icon}"
                                                            FontSize="14"
                                                            Foreground="#67C23A"
                                                            Text="&#xf08b;" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontWeight="SemiBold"
                                                            Foreground="#303133"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            Foreground="#909399"
                                                            Text="{Binding Description, StringFormat='- {0}'}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Visibility="{Binding HasFunctionalEnumPort, Converter={ui:BooleanToVisibilityConverter}}">
                                <StackPanel Margin="12,15,12,0" Orientation="Vertical">
                                    <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Icon}"
                                            FontSize="13"
                                            Foreground="#E6A23C"
                                            Text="&#xf0ca;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#E6A23C"
                                            Text="功能预设选项" />
                                    </StackPanel>

                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="11"
                                        Foreground="#909399"
                                        Text="请在下方列表中选择要应用的系统内置参数：" />

                                    <Border
                                        Height="36"
                                        Background="#FFFFFF"
                                        BorderBrush="#DCDFE6"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <ComboBox
                                            Padding="10,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="13"
                                            Foreground="#303133"
                                            ItemsSource="{Binding PresetOptions}"
                                            SelectedValue="{Binding ConstantValue, UpdateSourceTrigger=PropertyChanged}"
                                            SelectedValuePath="Option">
                                            <ComboBox.Resources>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Padding="4,2"
                                                        FontSize="13"
                                                        Text="{Binding Option}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>
                            </Grid>

                        </Grid>
                    </Border>
                </Grid>

                <StackPanel
                    Grid.Row="2"
                    Margin="20,10"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,12,0"
                        Padding="28,8"
                        Background="#FFFFFF"
                        BorderBrush="#DCDFE6"
                        Command="{Binding CancelCommand}"
                        Content="取消"
                        Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button
                        Padding="28,8"
                        Background="#409EFF"
                        BorderThickness="0"
                        Command="{Binding ConfirmCommand}"
                        Content="确定"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
