<UserControl
    x:Class="VisionMaster.Views.VariableBindingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:VisionMaster.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:ui="http://schemas.UI.com/ui"
    Width="880"
    Height="530"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="WindowStyle" Value="None" />
            <Setter Property="ResizeMode" Value="NoResize" />
            <Setter Property="SizeToContent" Value="WidthAndHeight" />
        </Style>
    </prism:Dialog.WindowStyle>

    <UserControl.Resources>
        <Style x:Key="NoWarningItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F7FA" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#ECF5FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Border Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="15"
                    Direction="270"
                    Opacity="0.15"
                    ShadowDepth="3"
                    Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border
                    Grid.Row="0"
                    ui:WindowDragBehavior.IsWindowDraggable="True"
                    Background="#F8F9FA"
                    BorderBrush="#EBEEF5"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0">
                    <TextBlock
                        Margin="20,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="#303133"
                        Text="变量绑定" />
                </Border>
                <Grid Grid.Row="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="250" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Background="#FFFFFF"
                            BorderBrush="#E4E7ED"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border
                                    Background="#F5F7FA"
                                    BorderBrush="#E4E7ED"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="6,6,0,0">
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="#606266"
                                        Text="当前算子输入" />
                                </Border>
                                <ListBox
                                    Grid.Row="1"
                                    Margin="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource NoWarningItemStyle}"
                                    ItemsSource="{Binding DisplayDataPort}"
                                    SelectedItem="{Binding SelectedInputPort}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,6">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Icon}"
                                                        FontSize="14"
                                                        Foreground="#E6A23C"
                                                        Text="&#xf090;" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontWeight="SemiBold"
                                                        Foreground="#303133"
                                                        Text="{Binding Definition.Name}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="#909399"
                                                        Text="{Binding Definition.DataTypeName, Converter={ui:TypeNameToFriendlyNameConverter}}" />
                                                </StackPanel>

                                                <Border
                                                    Grid.Row="1"
                                                    Margin="22,6,0,0"
                                                    Visibility="{Binding IsBound, Converter={StaticResource BooleanToVisibilityConverter}}">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock
                                                            Grid.Column="0"
                                                            Margin="0,0,5,0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Icon}"
                                                            FontSize="12"
                                                            Foreground="#67C23A"
                                                            Text="&#xf0c1;" />

                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="#67C23A"
                                                            Text="{Binding LinkedAddress, StringFormat='已绑定: {0}'}" />

                                                        <Button
                                                            Grid.Column="2"
                                                            Padding="5,0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.UnbindCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            Cursor="Hand">
                                                            <TextBlock
                                                                Name="UnbindIcon"
                                                                FontFamily="{StaticResource Icon}"
                                                                FontSize="12"
                                                                Foreground="#C0C4CC"
                                                                Text="&#xf00d;" />
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="MouseEnter">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation
                                                                                Storyboard.TargetName="UnbindIcon"
                                                                                Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                                                To="#F56C6C"
                                                                                Duration="0:0:0.1" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                                <EventTrigger RoutedEvent="MouseLeave">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation
                                                                                Storyboard.TargetName="UnbindIcon"
                                                                                Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                                                To="#C0C4CC"
                                                                                Duration="0:0:0.1" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter
                            Grid.Column="1"
                            Width="8"
                            HorizontalAlignment="Center"
                            Background="Transparent" />
                        <Border
                            Grid.Column="2"
                            Background="#FFFFFF"
                            BorderBrush="#E4E7ED"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border
                                    Background="#F5F7FA"
                                    BorderBrush="#E4E7ED"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="6,6,0,0">
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="#606266"
                                        Text="选择上游算子" />
                                </Border>
                                <ListBox
                                    Grid.Row="1"
                                    Margin="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource NoWarningItemStyle}"
                                    ItemsSource="{Binding TreeNodes}"
                                    SelectedItem="{Binding SelectedNode}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Icon}"
                                                    FontSize="16"
                                                    Foreground="#409EFF"
                                                    Text="{Binding Icon}" />
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Foreground="#303133"
                                                        Text="{Binding ModuleGroup}" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="10"
                                                        Foreground="#C0C4CC"
                                                        Text="{Binding Description}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter
                            Grid.Column="3"
                            Width="8"
                            HorizontalAlignment="Center"
                            Background="Transparent" />
                        <Border
                            Grid.Column="4"
                            Background="#FFFFFF"
                            BorderBrush="#E4E7ED"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border
                                    Background="#F0F9EB"
                                    BorderBrush="#E4E7ED"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="6,6,0,0">
                                    <TextBlock
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="#529B2E"
                                        Text="双击绑定输出变量" />
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Margin="10,10,10,5"
                                    Background="#F5F7FA"
                                    BorderThickness="0"
                                    CornerRadius="4">
                                    <TextBox
                                        Padding="8,6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#606266"
                                        Text="搜索变量..." />
                                </Border>
                                <ListBox
                                    Grid.Row="2"
                                    Margin="2,0,2,2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource NoWarningItemStyle}"
                                    ItemsSource="{Binding DisplayPorts}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="Transparent">
                                                <Grid.InputBindings>
                                                    <MouseBinding
                                                        Command="{Binding DataContext.DoublockClickBindCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="{Binding}"
                                                        MouseAction="LeftDoubleClick" />
                                                </Grid.InputBindings>

                                                <StackPanel Margin="2,4" Orientation="Horizontal">
                                                    <TextBlock
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Icon}"
                                                        FontSize="14"
                                                        Foreground="#67C23A"
                                                        Text="&#xf08b;" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontWeight="Bold"
                                                        Foreground="#303133"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="#909399"
                                                        Text="{Binding Description, StringFormat=' ({0})'}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,12,0"
                            Padding="28,8"
                            Background="#FFFFFF"
                            BorderBrush="#DCDFE6"
                            Command="{Binding CancelCommand}"
                            Content="取消"
                            Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4" />
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button
                            Padding="28,8"
                            Background="#409EFF"
                            BorderThickness="0"
                            Command="{Binding ConfirmCommand}"
                            Content="确定"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            Foreground="White">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>