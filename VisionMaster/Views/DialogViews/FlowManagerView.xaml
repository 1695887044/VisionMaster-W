<UserControl
    x:Class="VisionMaster.Views.DialogViews.FlowManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="800"
    Height="450"
    Background="White"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  按钮样式  -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="Background" Value="#3498db" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980b9" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  加密按钮样式  -->
        <Style
            x:Key="EncryptButtonStyle"
            BasedOn="{StaticResource ActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#27ae60" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  解密按钮样式  -->
        <Style
            x:Key="DecryptButtonStyle"
            BasedOn="{StaticResource ActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#e74c3c" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c0392b" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  禁用按钮样式  -->
        <Style
            x:Key="DisableButtonStyle"
            BasedOn="{StaticResource ActionButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#95a5a6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7f8c8d" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  DataGrid样式  -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#ecf0f1" />
            <Setter Property="BorderBrush" Value="#bdc3c7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#f8f9fa" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#34495e" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="BorderBrush" Value="#2c3e50" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3498db" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  标题和搜索  -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="Bold"
                Foreground="#2c3e50"
                Text="流程管理" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#34495e"
                    Text="搜索:" />
                <TextBox
                    Width="200"
                    Padding="8,5"
                    BorderBrush="#bdc3c7"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <!--  流程列表  -->
        <DataGrid
            Grid.Row="1"
            ItemsSource="{Binding Flows}"
            SelectedItem="{Binding SelectedFlow}">
            <DataGrid.Columns>
                <!--  流程名称  -->
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Flow.FlowName}"
                    Header="流程名称"
                    IsReadOnly="True" />

                <!--  调用类型  -->
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding InvokeTypeText}"
                    Header="调用类型"
                    IsReadOnly="True" />

                <!--  描述  -->
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding Flow.Description}"
                    Header="描述"
                    IsReadOnly="True" />

                <!--  状态  -->
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding StatusText}"
                    Header="状态"
                    IsReadOnly="True" />

                <!--  操作按钮  -->
                <DataGridTemplateColumn Width="320" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Command="{Binding DataContext.EncryptFlowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="加密"
                                    Style="{StaticResource EncryptButtonStyle}" />

                                <Button
                                    Command="{Binding DataContext.DecryptFlowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="解密"
                                    Style="{StaticResource DecryptButtonStyle}" />

                                <Button
                                    Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding EnabledText}"
                                    Style="{StaticResource DisableButtonStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!--  底部说明和关闭按钮  -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock
                    FontWeight="Bold"
                    Foreground="#34495e"
                    Text="说明：" />
                <TextBlock
                    Margin="10,5,0,0"
                    Foreground="#7f8c8d"
                    Text="• 启用/禁用：控制流程是否参与自动调用" />
                <TextBlock
                    Margin="10,2,0,0"
                    Foreground="#7f8c8d"
                    Text="• 加密/解密：保护流程内容不被未授权访问" />
                <TextBlock
                    Margin="10,2,0,0"
                    Foreground="#7f8c8d"
                    Text="• 调用类型：定时调用按指定间隔执行，变量调用在变量变化时触发" />
            </StackPanel>
            
            <Button
                Grid.Column="1"
                Command="{Binding CloseCommand}"
                Content="关闭"
                Padding="20,8"
                Background="#34495e"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand" />
        </Grid>
    </Grid>
</UserControl>
