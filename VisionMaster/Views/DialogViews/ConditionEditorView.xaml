<UserControl
    x:Class="VisionMaster.Views.DialogViews.ConditionEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:prism="http://prismlibrary.com/"
    Width="950"
    Height="700"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="#F4F7FB"
    FontFamily="Microsoft YaHei">
    <UserControl.Resources>
        <!--  基础按钮样式 (更加圆润的现代感)  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#409EFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#66B1FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#3A8EE6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  快捷插入按钮 (软色块)  -->
        <Style x:Key="TagButton" TargetType="Button">
            <Setter Property="Background" Value="#ECF5FF" />
            <Setter Property="Foreground" Value="#409EFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D9ECFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  修复后的输入框样式 (彻底解决文字被切断、显示不全的问题)  -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#DCDFE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#409EFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  卡片包裹器样式  -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#EBEEF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="12"
                        Opacity="0.03"
                        ShadowDepth="4"
                        Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  左侧：分支列表栏  -->
        <Border
            Grid.Column="0"
            Background="White"
            BorderBrush="#E4E7ED"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="65" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Margin="25,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#303133"
                    Text="逻辑分支" />

                <!--  Notion 风格的高级悬浮列表  -->
                <ListBox
                    Grid.Row="1"
                    Margin="10,10,10,0"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectedIndex="-1"
                    ItemsSource="{Binding Branches}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectedItem="{Binding SelectedBranch}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                                <Ellipse
                                    Width="6"
                                    Height="6"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Fill="#C0C4CC" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="{Binding StepName}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Height" Value="42" />
                            <Setter Property="Margin" Value="0,0,0,5" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#606266" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                            <ContentPresenter
                                                Margin="{TemplateBinding Padding}"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F5F7FA" />
                                                <Setter Property="Foreground" Value="#303133" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#ECF5FF" />
                                                <Setter Property="Foreground" Value="#1890FF" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!--  右侧：主控区  -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="1.2*"
                    MinHeight="150"
                    MaxHeight="400" />
                <RowDefinition Height="15" />
                <RowDefinition Height="2*" MinHeight="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  1. 变量引脚定义区  -->
            <Border
                Grid.Row="0"
                Padding="20,15,20,5"
                Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,15" LastChildFill="False">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#303133"
                            Text="输入变量配置 (Local Variables)" />
                        <Button
                            Padding="15,6"
                            Command="{Binding AddVariableCommand}"
                            Content="+ 新增变量"
                            DockPanel.Dock="Right"
                            Style="{StaticResource PrimaryButton}" />
                    </DockPanel>

                    <DataGrid
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        Background="White"
                        BorderBrush="#E4E7ED"
                        BorderThickness="1"
                        CanUserAddRows="False"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#F0F2F5"
                        ItemsSource="{Binding Variables}"
                        MinRowHeight="45"
                        RowHeaderWidth="0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F5F7FA" />
                                <Setter Property="Padding" Value="15,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="#909399" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <!--  第一列：别名  -->
                            <DataGridTemplateColumn Width="150" Header="别名 (Alias)">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            Margin="10,0"
                                            Style="{StaticResource ModernTextBox}"
                                            Text="{Binding AliasName, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!--  第二列：绑定上游  -->
                            <DataGridTemplateColumn Width="*" Header="绑定的上游数据源">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="#909399"
                                                Text="{Binding SourceAddress, TargetNullValue='尚未绑定上游端口'}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Button
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Padding="10,4"
                                                Command="{Binding DataContext.BindVariableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="🔗 重新绑定"
                                                Style="{StaticResource TagButton}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!--  第三列：删除  -->
                            <DataGridTemplateColumn Width="80" Header="操作">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.RemoveVariableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="删除"
                                            Cursor="Hand"
                                            Foreground="#F56C6C" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!--  动态比例分割线  -->
            <GridSplitter
                Grid.Row="1"
                Height="3"
                Margin="10,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="#E4E7ED"
                Cursor="SizeNS"
                ShowsPreview="True" />

            <!--  2. 表达式编辑器  -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="#303133"
                        Text="{Binding SelectedBranch.StepName, StringFormat='{}为分支 [ {0} ] 编写逻辑判断表达式:'}" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="130" Margin="0,0,0,10" Padding="0,0,5,0">
                        <WrapPanel Orientation="Horizontal">

                            <!-- 1. 动态变量区 -->
                            <TextBlock Text="引脚变量:" VerticalAlignment="Center" Margin="0,0,8,10" Foreground="#909399" FontSize="13"/>
                            <ItemsControl ItemsSource="{Binding Variables}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding AliasName}" Style="{StaticResource TagButton}" Click="QuickInsert_Click"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Rectangle Width="1" Height="20" Fill="#DCDFE6" Margin="10,0,15,10" VerticalAlignment="Top"/>

                            <!-- 2. 比较与逻辑区 -->
                            <TextBlock Text="逻辑比较:" VerticalAlignment="Center" Margin="0,0,8,10" Foreground="#909399" FontSize="13"/>
                            <Button Content="&gt;" Tag="&gt;" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="大于"/>
                            <Button Content="&lt;" Tag="&lt;" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="小于"/>
                            <Button Content="==" Tag="==" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="等于"/>
                            <Button Content="!=" Tag="!=" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="不等于"/>
                            <Button Content="&amp;&amp;" Tag="&amp;&amp;" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="并且 (And)"/>
                            <Button Content="||" Tag="||" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="或者 (Or)"/>
                            <Button Content="!" Tag="!" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="取反 (Not)"/>

                            <Rectangle Width="1" Height="20" Fill="#DCDFE6" Margin="10,0,15,10" VerticalAlignment="Top"/>

                            <!-- 3. 运算与函数区 -->
                            <TextBlock Text="数学运算:" VerticalAlignment="Center" Margin="0,0,8,10" Foreground="#909399" FontSize="13"/>
                            <Button Content="( )" Tag="()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="括号 (提高优先级)"/>
                            <Button Content="+" Tag="+" Style="{StaticResource TagButton}" Click="QuickInsert_Click"/>
                            <Button Content="-" Tag="-" Style="{StaticResource TagButton}" Click="QuickInsert_Click"/>
                            <Button Content="*" Tag="*" Style="{StaticResource TagButton}" Click="QuickInsert_Click"/>
                            <Button Content="/" Tag="/" Style="{StaticResource TagButton}" Click="QuickInsert_Click"/>

                            <Button Content="Math.Abs()" Tag="Math.Abs()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="绝对值 (常用于公差判断)"/>
                            <Button Content="Math.Round()" Tag="Math.Round()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="四舍五入"/>
                            <Button Content="Math.Sqrt()" Tag="Math.Sqrt()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="开平方 (常用于算距离)"/>
                            <Rectangle Width="1" Height="20" Fill="#DCDFE6" Margin="10,0 ,15,10" VerticalAlignment="Top"/>
                            <TextBlock Text="字符串:" VerticalAlignment="Center" Margin="0,0,8,10" Foreground="#909399" FontSize="13"/>

                            <Button Content="Contains()" Tag=".Contains()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="包含某个字符"/>
                            <Button Content="StartsWith()" Tag=".StartsWith()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="以...开头"/>
                            <Button Content="IsNullOrEmpty()" Tag="string.IsNullOrEmpty()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="是否为空"/>
                            <Button Content="Length" Tag=".Length" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="获取字符串长度"/>
                            <Button Content="Trim()" Tag=".Trim()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="去除首尾空格"/>
                            <Button Content="ToUpper()" Tag=".ToUpper()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="转大写"/>
                            <Button Content="ToLower()" Tag=".ToLower()" Style="{StaticResource TagButton}" Click="QuickInsert_Click" ToolTip="转小写"/>
                        </WrapPanel>
                    </ScrollViewer>

                    <!--  AvalonEdit 编辑器  -->
                    <Border
                        Grid.Row="2"
                        BorderBrush="#E4E7ED"
                        BorderThickness="1"
                        ClipToBounds="True"
                        CornerRadius="4">
                        <avalonEdit:TextEditor
                            x:Name="txtExpression"
                            Padding="10"
                            Background="#FAFCFF"
                            FontFamily="Consolas"
                            FontSize="15"
                            ShowLineNumbers="True"
                            SyntaxHighlighting="C#"
                            TextChanged="TxtExpression_TextChanged" />
                    </Border>
                </Grid>
            </Border>

            <!--  3. 底部保存  -->
            <StackPanel
                Grid.Row="3"
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="90"
                    Margin="0,0,15,0"
                    Padding="0,8"
                    Background="White"
                    BorderBrush="#DCDFE6"
                    BorderThickness="1"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Cursor="Hand"
                    Foreground="#606266" />
                <Button
                    Width="130"
                    Command="{Binding SaveCommand}"
                    Content="保存并应用"
                    Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>