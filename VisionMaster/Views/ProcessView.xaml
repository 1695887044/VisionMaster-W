<UserControl
    x:Class="VisionMaster.Views.ProcessView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:enums="clr-namespace:VisionMaster"
    xmlns:local="clr-namespace:VisionMaster.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:VisionMaster.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:ui="http://schemas.UI.com/ui"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ui:BindingProxy x:Key="ModuleData" Data="{Binding}" />
    </UserControl.Resources>
    <TreeView
        x:Name="StepTree"
        dd:DragDrop.DragHandler="{Binding}"
        dd:DragDrop.DropHandler="{Binding}"
        dd:DragDrop.IsDragSource="True"
        dd:DragDrop.IsDropTarget="True"
        dd:DragDrop.UseDefaultDragAdorner="True"
        dd:DragDrop.UseDefaultEffectDataTemplate="True"
        ui:TreeViewBehavior.BindableSelectedItem="{Binding SelectStep}"
        ItemsSource="{Binding Workspace.CurrentFlow.Steps}"
        PreviewMouseRightButtonUp="moduleTree_PreviewMouseRightButtonDown">
        <TreeView.Resources>
            <DataTemplate DataType="{x:Type models:ActionStep}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Icon}"
                        Foreground="#4A90E2"
                        Text="{Binding Icon}" />
                    <TextBlock
                        MaxWidth="140"
                        Margin="2,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding StepName}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding StepName}" />
                    <TextBlock
                        MaxWidth="180"
                        Margin="2,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="Green"
                        Text="{Binding Description}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding Description}" />
                </StackPanel>
            </DataTemplate>
            <HierarchicalDataTemplate DataType="{x:Type models:ConditionStep}" ItemsSource="{Binding Children}">
                <StackPanel
                    Margin="0,10,0,4"
                    Background="Transparent"
                    Orientation="Horizontal"
                    ToolTip="点击配置分支输入变量">

                    <Rectangle
                        Width="3"
                        Height="14"
                        Margin="0,0,8,0"
                        Fill="#DCDFE6"
                        RadiusX="1.5"
                        RadiusY="1.5" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#909399"
                        Text="逻辑路由" />

                    <TextBlock
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#C0C4CC"
                        Text="{Binding StepName, StringFormat='-[ {0} ]'}" />
                </StackPanel>
            </HierarchicalDataTemplate>
            <HierarchicalDataTemplate DataType="{x:Type models:StepCollection}" ItemsSource="{Binding Steps}">
                <!-- 基础卡片样式 (加入阴影和更柔和的圆角，强调它是可以拖入算子的容器) -->
                <Border x:Name="BranchContainer"
            MinWidth="180" MinHeight="32" 
            Margin="0,4,0,4" Padding="10,6"
            Background="#F0F7FF" 
            BorderBrush="#CBE5FF" 
            BorderThickness="1" 
            CornerRadius="6"
            ToolTip="将算子拖入此分支内部">

                    <StackPanel Orientation="Horizontal">
                        <!-- 状态指示灯 -->
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,10,0" Fill="#409EFF" VerticalAlignment="Center"/>

                        <!-- 分支文本 -->
                        <TextBlock x:Name="BranchText" 
                       VerticalAlignment="Center" 
                       FontWeight="SemiBold" 
                       Foreground="#303133" 
                       Text="{Binding DisplayName}" />
                    </StackPanel>
                </Border>

                <!-- 🌟 神奇的触发器：让卡片学会自己变色 -->
                <HierarchicalDataTemplate.Triggers>

                    <!-- 场景 1：如果是 Else 分支 -> 变成低调的灰色 -->
                    <DataTrigger Binding="{Binding BranchType}" Value="Else">
                        <Setter TargetName="BranchContainer" Property="Background" Value="#F5F7FA" />
                        <Setter TargetName="BranchContainer" Property="BorderBrush" Value="#E4E7ED" />
                        <Setter TargetName="StatusDot" Property="Fill" Value="#A8ABB2" />
                        <Setter TargetName="BranchText" Property="Foreground" Value="#606266" />
                    </DataTrigger>

                    <DataTrigger Binding="{Binding BranchType}" Value="Default">
                        <Setter TargetName="BranchContainer" Property="Background" Value="#F5F7FA" />
                        <Setter TargetName="BranchContainer" Property="BorderBrush" Value="#E4E7ED" />
                        <Setter TargetName="StatusDot" Property="Fill" Value="#A8ABB2" />
                        <Setter TargetName="BranchText" Property="Foreground" Value="#606266" />
                    </DataTrigger>

                    <!-- 场景 2：如果是 If 分支，但是表达式为空！ -> 变成危险的红色警告 -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding BranchType}" Value="If" />
                            <Condition Binding="{Binding Expression}" Value="{x:Null}" />
                        </MultiDataTrigger.Conditions>
                        <Setter TargetName="BranchContainer" Property="Background" Value="#FEF0F0" />
                        <Setter TargetName="BranchContainer" Property="BorderBrush" Value="#FBC4C4" />
                        <Setter TargetName="StatusDot" Property="Fill" Value="#F56C6C" />
                        <Setter TargetName="BranchText" Property="Foreground" Value="#F56C6C" />
                    </MultiDataTrigger>

                    <!-- 兼容 Expression 为 "" (空字符串) 的情况 -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding BranchType}" Value="If" />
                            <Condition Binding="{Binding Expression}" Value="" />
                        </MultiDataTrigger.Conditions>
                        <Setter TargetName="BranchContainer" Property="Background" Value="#FEF0F0" />
                        <Setter TargetName="BranchContainer" Property="BorderBrush" Value="#FBC4C4" />
                        <Setter TargetName="StatusDot" Property="Fill" Value="#F56C6C" />
                        <Setter TargetName="BranchText" Property="Foreground" Value="#F56C6C" />
                    </MultiDataTrigger>

                </HierarchicalDataTemplate.Triggers>
            </HierarchicalDataTemplate>
        </TreeView.Resources>
        <TreeView.ContextMenu>
            <ContextMenu DataContext="{Binding Data, Source={StaticResource ModuleData}}" FontFamily="{StaticResource Icon}">
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.AddElseIf}"
                    Header="添加 ElseIf 分支"
                    Icon="code-branch"
                    Visibility="{Binding IsIfNodeSelected, Converter={ui:BooleanToVisibilityConverter}}" />

                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.AddElse}"
                    Header="添加 Else 分支"
                    Icon="code-branch"
                    Visibility="{Binding IsIfNodeSelected, Converter={ui:BooleanToVisibilityConverter}}" />

                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.AddCase}"
                    Header="添加 Case 分支"
                    Icon="code-branch"
                    Visibility="{Binding IsSwitchNodeSelected, Converter={ui:BooleanToVisibilityConverter}}" />

                <Separator Visibility="{Binding IsIfNodeSelected, Converter={ui:BooleanToVisibilityConverter}}" />

                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.Rename}"
                    Header="重命名"
                    Icon="pen-to-square" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.EditComment}"
                    Header="编辑注释"
                    Icon="comment-lines" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.ExecuteSelected}"
                    Header="执行选中模块"
                    Icon="play" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.ExecuteFromHere}"
                    Header="从此处执行"
                    Icon="forward" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.ShowAll}"
                    Header="显示所有"
                    Icon="eye" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.EnableSuperTool}"
                    Header="启用超级工具"
                    Icon="wrench" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.SetBreakpoint}"
                    Header="设置断点"
                    Icon="circle-dot" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.ModuleParameters}"
                    Header="模块参数"
                    Icon="sliders" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.Cut}"
                    Header="剪切"
                    Icon="scissors" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.Copy}"
                    Header="复制"
                    Icon="copy" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.Paste}"
                    Header="粘贴"
                    Icon="paste" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.Disable}"
                    Header="禁用"
                    Icon="ban" />
                <MenuItem
                    Command="{Binding ModuleActionCommand}"
                    CommandParameter="{x:Static enums:ModuleCommandAction.Delete}"
                    Header="删除模块"
                    Icon="trash" />
            </ContextMenu>
        </TreeView.ContextMenu>
    </TreeView>

</UserControl>
