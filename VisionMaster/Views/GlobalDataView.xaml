<UserControl
    x:Class="VisionMaster.Views.GlobalDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:ui="http://schemas.UI.com/ui"
    xmlns:local="clr-namespace:VisionMaster.Views"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F0F7FF"/>
                    <Setter Property="Foreground" Value="#303133"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <DataGrid
            AutoGenerateColumns="False"
            Background="Transparent"
            BorderThickness="0"
            CanUserAddRows="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="#EBEEF5"
            IsReadOnly="True"
            ItemsSource="{Binding DisplayNodes}"
            RowHeight="36">

            <DataGrid.Columns>
                <DataGridTemplateColumn x:Name="colName" Width="180" Header="变量名称">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Background="Transparent" Orientation="Horizontal">

                                <!-- 层级缩进 -->
                                <Border Width="{Binding Level, Converter={ui:LevelToIndentConverter}}" />

                                <!-- 展开/折叠按钮 -->
                                <ToggleButton
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.ToggleNodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                    Template="{StaticResource ExpandToggleButtonTemplate}"
                                    Visibility="{Binding IsContainer, Converter={ui:BooleanToVisibilityConverter}}" />

                                <!-- 非容器节点占位 -->
                                <Border Width="{Binding IsContainer, Converter={ui:BooleanToWidthConverter}, ConverterParameter=22}" />

                                <TextBlock VerticalAlignment="Center" Text="{Binding Name}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#409EFF" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="1">
                                                    <Setter Property="Foreground" Value="#909399" />
                                                    <Setter Property="FontWeight" Value="Normal" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn x:Name="colType" Width="120" Binding="{Binding TypeName}" Foreground="#909399" Header="数据类型" />
                <DataGridTextColumn x:Name="colVal" Width="200" Binding="{Binding DisplayValue}" FontWeight="Bold" Foreground="#67C23A" Header="当前值" />
                <DataGridTextColumn x:Name="colDesc" Width="*" Binding="{Binding Description}" Foreground="#C0C4CC" Header="说明" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>