<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:UI.CustomControl">

    <Style TargetType="{x:Type local:Popover}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Popover}">
                    <Grid x:Name="RootNode">

                        <ContentPresenter />

                        <Popup IsOpen="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=RootNode}"
                               Placement="{TemplateBinding Placement}"
                               AllowsTransparency="True"
                               StaysOpen="False"
                               PopupAnimation="Fade">

                            <Border Background="#FFFFFF" 
                                    CornerRadius="6" 
                                    Margin="16" 
                                    Padding="12"
                                    BorderBrush="#E5E5E5"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" Opacity="0.12" ShadowDepth="4" Direction="270" Color="Black"/>
                                </Border.Effect>

                                <ContentPresenter Content="{TemplateBinding FlyoutContent}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>