<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:UI.CustomControl"
    xmlns:models="clr-namespace:UI.Models">

    <Style TargetType="{x:Type local:LogConsole}">
        <Style.Resources>
            <Style TargetType="{x:Type GroupItem}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type GroupItem}">
                            <StackPanel>
                                <Border
                                    Margin="0,4"
                                    Padding="12,6"
                                    Background="#252526"
                                    BorderBrush="#3E3E42"
                                    BorderThickness="0,1">
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="#858585"
                                            Text="📁 " />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource AccentBrush}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Margin="4,0,0,0"
                                            FontSize="12"
                                            Foreground="#666666"
                                            Text="{Binding ItemCount, StringFormat=' ({0} 条记录)'}" />
                                    </StackPanel>
                                </Border>
                                <ItemsPresenter />
                            </StackPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>

        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True" />
        <Setter Property="Background" Value="#FAFAFA" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="BorderBrush" Value="#E5E5E5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />

        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />

        <Setter Property="AlternationCount" Value="2" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LogConsole}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                        <ScrollViewer x:Name="PART_ScrollViewer" Focusable="False">
                            <ItemsPresenter Margin="{TemplateBinding Padding}" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="#F0F0F0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F3F4F6" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5F3FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#CCE8FF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate DataType="{x:Type models:LogItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            x:Name="ColorBar"
                            Width="4"
                            HorizontalAlignment="Left" />

                        <TextBlock
                            Grid.Column="1"
                            Margin="12,8,16,8"
                            VerticalAlignment="Center"
                            FontFamily="Consolas"
                            FontSize="12"
                            Foreground="#888888"
                            Text="{Binding Time, StringFormat={}{0:HH:mm:ss.fff}}" />

                        <Border
                            Grid.Column="2"
                            Margin="0,8,16,8"
                            Padding="6,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="#E9ECEF"
                            CornerRadius="4">
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#495057"
                                Text="{Binding Source}" />
                        </Border>

                        <TextBlock
                            x:Name="TxtMessage"
                            Grid.Column="3"
                            Margin="0,8,12,8"
                            VerticalAlignment="Center"
                            FontFamily="Consolas"
                            Foreground="#333333"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Info}">
                            <Setter TargetName="ColorBar" Property="Background" Value="#0078D4" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Success}">
                            <Setter TargetName="ColorBar" Property="Background" Value="#107C10" />
                            <Setter TargetName="TxtMessage" Property="Foreground" Value="#107C10" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Warning}">
                            <Setter TargetName="ColorBar" Property="Background" Value="#D83B01" />
                            <Setter TargetName="TxtMessage" Property="Foreground" Value="#D83B01" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Error}">
                            <Setter TargetName="ColorBar" Property="Background" Value="#D13438" />
                            <Setter TargetName="TxtMessage" Property="Foreground" Value="#D13438" />
                            <Setter TargetName="TxtMessage" Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>