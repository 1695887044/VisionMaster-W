<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:UI.CustomControl">

    <SolidColorBrush x:Key="SidebarBg" Color="#F1F5F9" />
    <SolidColorBrush x:Key="ContentBg" Color="#F8FAFC" />
    <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6" />
    <SolidColorBrush x:Key="TextMain" Color="#1E293B" />
    <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
    </Style>
    <Style x:Key="DarkFlatTabItemStyle" TargetType="TabItem">
        <Setter Property="Foreground" Value="#888888" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border
                        x:Name="Border"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                        <ContentPresenter
                            x:Name="ContentSite"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#DDDDDD" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="#555555" />
                            <Setter TargetName="Border" Property="BorderThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="LightFlatTabItemStyle" TargetType="TabItem">
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border
                        x:Name="Border"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="0,0,0,3">
                        <ContentPresenter
                            x:Name="ContentSite"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#111111" />
                            <Setter TargetName="Border" Property="Background" Value="#F3F3F3" />
                            <Setter TargetName="Border" Property="CornerRadius" Value="4,4,0,0" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#000000" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="#005FB8" />
                            <Setter TargetName="Border" Property="Background" Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:CardPropertyGrid}">
        <Setter Property="Background" Value="{StaticResource ContentBg}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CardPropertyGrid}">
                    <Border
                        Background="{TemplateBinding Background}"
                        ClipToBounds="True"
                        CornerRadius="8">
                        <TabControl
                            x:Name="PART_TabControl"
                            Background="Transparent"
                            BorderThickness="0"
                            TabStripPlacement="Left">
                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid IsItemsHost="False">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" MinWidth="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            Background="{StaticResource SidebarBg}"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,1,0">
                                            <ScrollViewer
                                                Padding="0,15"
                                                HorizontalScrollBarVisibility="Disabled"
                                                VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </Border>

                                        <Border Grid.Column="1" Background="{StaticResource ContentBg}">
                                            <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" />
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </TabControl.Template>

                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem">
                                    <Setter Property="Margin" Value="12,2,12,2" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border
                                                    x:Name="BaseBorder"
                                                    Background="Transparent"
                                                    CornerRadius="6"
                                                    SnapsToDevicePixels="True">
                                                    <Grid Height="40">
                                                        <Border
                                                            x:Name="ActiveMark"
                                                            Width="3"
                                                            Height="16"
                                                            Margin="8,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            Background="Transparent"
                                                            CornerRadius="2" />
                                                        <ContentPresenter
                                                            x:Name="TextHost"
                                                            Margin="24,0,10,0"
                                                            VerticalAlignment="Center"
                                                            ContentSource="Header"
                                                            TextBlock.Foreground="#64748B" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BaseBorder" Property="Background" Value="#E2E8F0" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="BaseBorder" Property="Background" Value="White" />
                                                        <Setter TargetName="ActiveMark" Property="Background" Value="{StaticResource AccentBlue}" />
                                                        <Setter TargetName="TextHost" Property="TextBlock.Foreground" Value="{StaticResource TextMain}" />
                                                        <Setter TargetName="TextHost" Property="TextBlock.FontWeight" Value="SemiBold" />
                                                        <Setter TargetName="BaseBorder" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect
                                                                    BlurRadius="8"
                                                                    Opacity="0.05"
                                                                    ShadowDepth="1" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.ItemContainerStyle>

                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <ScrollViewer Padding="40" VerticalScrollBarVisibility="Auto">
                                        <Border
                                            Padding="32"
                                            Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="20"
                                                    Opacity="0.04"
                                                    ShadowDepth="4" />
                                            </Border.Effect>
                                            <ContentPresenter Content="{Binding}" />
                                        </Border>
                                    </ScrollViewer>
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:FlatPropertyGrid}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FlatPropertyGrid}">
                    <Border Background="{TemplateBinding Background}">
                        <TabControl
                            x:Name="PART_TabControl"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource LightFlatTabItemStyle}">
                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border
                                            x:Name="HeaderPanel"
                                            Grid.Row="0"
                                            Margin="12,8,12,0"
                                            BorderBrush="#E5E5E5"
                                            BorderThickness="0,0,0,1">
                                            <TabPanel
                                                Margin="0,0,0,-1"
                                                IsItemsHost="true"
                                                KeyboardNavigation.TabIndex="1" />
                                        </Border>

                                        <ContentPresenter
                                            x:Name="PART_SelectedContentHost"
                                            Grid.Row="1"
                                            Margin="0,8,0,0"
                                            ContentSource="SelectedContent" />
                                    </Grid>

                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="1">
                                            <Setter TargetName="HeaderPanel" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                            <Setter TargetName="HeaderPanel" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </TabControl.Template>
                        </TabControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>